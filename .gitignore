# ##############################################################################
# Apna Restorant - Root .gitignore
# ##############################################################################

# Dependency directories
node_modules/
**/node_modules/

# Build and distribution directories
dist/
**/dist/
build/
**/build/
out/
**/out/
.next/
.nuxt/
.docusaurus/

# Environment files (sensitive keys)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
**/.env
**/.env.local
**/.env.development
**/.env.test
**/.env.production

# Logs and databases
logs/
**/logs/
backups/
**/backups/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Testing & Coverage
coverage/
**/coverage/
.nyc_output/
.jest/
.playwright/
tests/results/

# Editor and IDE configurations
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.classpath
.project
.settings/
*.sublime-workspace
*.sublime-project

# Operating System Files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Docker / Compose temporary data
.docker/
*data/

# Documentation
docs/
